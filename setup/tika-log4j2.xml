<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <!-- One-line format: level, timestamp, short message — no stack traces -->
      <PatternLayout pattern="%level %d{HH:mm:ss} %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <!-- PDFBox: suppress graphics state and font warnings (95% of log noise) -->
    <Logger name="org.apache.pdfbox" level="FATAL" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>

    <!-- POI (Office docs): only fatal errors -->
    <Logger name="org.apache.poi" level="FATAL" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>

    <!-- Tika parsers: errors only (suppresses per-file warnings) -->
    <Logger name="org.apache.tika" level="ERROR" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>

    <!-- CXF/Jetty transport: errors only -->
    <Logger name="org.apache.cxf" level="ERROR" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>

    <Root level="WARN">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
