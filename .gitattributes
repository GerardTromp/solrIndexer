# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly mark file types as text
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf
*.bat text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pkl binary
*.pickle binary
*.gz binary
*.zip binary
